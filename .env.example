# .env.example – Template biến môi trường cho developer local
# ============================================================
# HƯỚNG DẪN SỬ DỤNG:
#   1. Copy file này thành .env:  cp .env.example .env
#   2. Điền giá trị thật vào file .env
#   3. File .env đã có trong .gitignore – KHÔNG bao giờ bị commit
#
# Khi chạy CI/CD (GitHub Actions), các biến này được set tự động
# qua GitHub Secrets → Settings → Secrets and variables → Actions
# ============================================================

# Credentials đăng nhập SauceDemo
APP_USERNAME=your_username_here
APP_PASSWORD=your_password_here

# URL môi trường (tùy chọn - mặc định đã có trong config.properties)
BASE_URL=https://www.saucedemo.com

# Browser mặc định khi chạy local (chrome hoặc firefox)
BROWSER=chrome
